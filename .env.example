# ------------------------------------------------------------------------------
# APPLICATION ENVIRONMENT CONFIGURATIONS
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# DATABASE CONNECTION (POSTGRESQL)
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://username:password@localhost:5432/your_database_name?schema=public"

# ------------------------------------------------------------------------------
# AUTHENTICATION & SECURITY TOKENS (JWT & BETTER-AUTH)
# ------------------------------------------------------------------------------
BETTER_AUTH_SECRET=your_super_secret_better_auth_key_at_least_32_characters
BETTER_AUTH_URL=http://localhost:5000

ACCESS_TOKEN_SECRET=your_jwt_access_token_secret_key_here
REFRESH_TOKEN_SECRET=your_jwt_refresh_token_secret_key_here

ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# BETTER-AUTH SESSION CONFIGURATIONS (In Seconds or Human-readable format)
BETTER_AUTH_SESSION_TOKEN_EXPIRES_IN=604800
BETTER_AUTH_SESSION_TOKEN_UPDATE_AGE=86400

# ------------------------------------------------------------------------------
# PAYMENT GATEWAY (STRIPE)
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
ADMIN_PASSWORD=12345678
# ------------------------------------------------------------------------------
# IMAGE HOSTING (CLOUDINARY) - Currently Commented Out in Code
# ------------------------------------------------------------------------------
# CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret
