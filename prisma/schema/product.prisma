model Product {
  id             String            @id @default(uuid())
  name           String
  description    String
  price          Float
  category       ProductCategories
  remainingStock Int
  image          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  orderItems      OrderItem[]

  @@map("products")
  orders Order[]
}
